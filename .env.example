TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Optional, but recommended for high-quality Russian and Uzbek news rewriting.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Runtime settings
DATABASE_PATH=./data/news_bot.sqlite3
TIMEZONE=Asia/Tashkent
POST_INTERVAL_MINUTES=60
MORNING_BRIEF_TIME=09:00
AFTERNOON_UPDATE_TIME=15:30
MAX_DAILY_POSTS=5
MIN_IMPORTANCE_SCORE=55
COLLECTION_LOOKBACK_HOURS=48
HEALTH_HOST=0.0.0.0
HEALTH_PORT=8006

# Comma-separated Telegram user IDs allowed to use admin commands.
ADMIN_USER_IDS=
